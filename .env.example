# =============================================================================
# PDFWiki V2 — Environment Configuration
# CLI arguments and exported env variables take precedence over values listed here.
# =============================================================================


# ── Global LLM settings ───────────────────────────────────────────────────────
# Used by both passes unless overridden by PASS1_* / PASS2_* below.

LLM_PROVIDER=openai_compat       # openai_compat | anthropic
LLM_BASE_URL=http://localhost:11434/v1 # Ollama default; change for other providers
LLM_MODEL=llama3.1:8b            # Model identifier (Ollama name, OpenRouter slug, etc.)


# ── API keys ──────────────────────────────────────────────────────────────────
# Set the key for whichever provider(s) you use. Leave others blank.

LLM_API_KEY=                     # Generic key — overrides all provider-specific keys below
ANTHROPIC_API_KEY=               # Required when LLM_PROVIDER=anthropic
OPENROUTER_API_KEY=              # Required for OpenRouter usage
OPENAI_API_KEY=                  # Required for OpenAI or compatible services that need a key


# ── Hybrid mode (two different backends for each pass) ────────────────────────
# If these are set, they override the global LLM_* values for that pass.
# Typical setup: local Ollama for Pass 1, API model for Pass 2.

PASS1_PROVIDER=openai_compat
PASS1_BASE_URL=http://localhost:11434/v1
PASS1_MODEL=llama3.1:8b

PASS2_PROVIDER=openai_compat
PASS2_BASE_URL= "URL-TO-API" # OpenRouter example: https://openrouter.ai/api/v1
PASS2_MODEL=your/model-here:free # Example: meta-llama/llama-3.3-70b-instruct:free

# OpenRouter only: comma-separated list of fallback models if the primary is unavailable
# e.g. anthropic/claude-3-haiku,openai/gpt-4o-mini
# Other providers silently ignore this variable even if set.
PASS2_FALLBACK_MODELS=openrouter/free

# ── Pipeline settings ─────────────────────────────────────────────────────────

TWO_PASS=1                       # 1 = two-pass extraction (recommended), 0 = legacy single-pass
PIPELINE_BATCH_SIZE=2            # Chunks processed per LLM batch
PIPELINE_MAX_WORKERS=5           # Parallel workers for LLM calls
PIPELINE_MAX_CHUNKS=             # Max chunks to process (blank = entire document)
PIPELINE_MIN_FACTS_PER_CONCEPT=1 # Prune concepts with at most this many facts


# ── Output settings ───────────────────────────────────────────────────────────

ENHANCED_PAGE_MODE=1
# 1 = wiki-style pages with templates and wikilinks
# 0 = standard pages (definition + key points + related)

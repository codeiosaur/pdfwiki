# =============================================================================
# PDFWiki V2 — Environment Configuration
# Precedence (standard Unix chain):  shell env vars > .env > backends.yaml
# See backends.yaml.example for backend pool/topology config.
# =============================================================================


# ── API keys ──────────────────────────────────────────────────────────────────
# Set the key for whichever provider(s) you use. Leave others blank.

ANTHROPIC_API_KEY=               # Required when using Anthropic models directly
OPENROUTER_API_KEY=              # Required for OpenRouter usage
OPENAI_API_KEY=                  # Required for OpenAI or compatible services that need a key
LLM_API_KEY=                     # Generic fallback — used when no provider-specific key is set
OPENROUTER_ZDR=0                 # 1/true/yes/on to send the zdr flag on every OpenRouter request
                                 # (can also be set per-backend in backends.yaml)


# ── Backend topology ──────────────────────────────────────────────────────────
# There are two ways to configure which models run each pass:
#
#  A) backends.yaml  (recommended for most setups)
#     Supports named backends, multiple backends per pass (round-robin pool),
#     per-backend ZDR/fallback_models, and native YAML comments.
#     When this file is present, the env vars below act as per-pass overrides
#     for quick one-off changes without editing the file.
#     See backends.yaml.example for the format.
#
#  B) Env vars only  (simpler — good for a single backend per pass)
#     When no backends.yaml is present, the env vars below are the sole config.
#     Set PASS{N}_MODEL / PASS{N}_BASE_URL for each pass, and optionally
#     LLM_* as shared defaults when per-pass vars are not set.
#
#
# Per-pass settings — work in both modes (A and B):
#
# PASS1_PROVIDER=openai_compat           # Provider: openai_compat or anthropic
# PASS1_BASE_URL=http://localhost:11434/v1
# PASS1_MODEL=llama3.1:8b
# PASS1_MAX_TOKENS=                      # Leave blank for provider default
# PASS1_ZDR=0                            # 1 = enable ZDR for this pass (OpenRouter only)
# PASS1_FALLBACK_MODELS=                 # Comma-separated fallbacks (OpenRouter only)
#
# PASS2_PROVIDER=openai_compat
# PASS2_BASE_URL=http://localhost:11434/v1
# PASS2_MODEL=llama3.1:8b
# PASS2_MAX_TOKENS=
# PASS2_ZDR=0
# PASS2_FALLBACK_MODELS=
#
# PASS3_PROVIDER=openai_compat
# PASS3_BASE_URL=http://localhost:11434/v1
# PASS3_MODEL=llama3.1:8b
# PASS3_MAX_TOKENS=
# PASS3_ZDR=0
# PASS3_FALLBACK_MODELS=
#
#
# Global defaults — used when a per-pass var is not set (mode B, or env override path):
#
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1:8b
# LLM_MAX_TOKENS=                        # Leave blank for provider default


# ── Pipeline settings ─────────────────────────────────────────────────────────

TWO_PASS=1                       # 1 = two-pass extraction (recommended), 0 = legacy single-pass
# Streaming overlaps Pass 1 and Pass 2 so that concept assignment begins while extraction
# is still running. Only beneficial when the two passes use different infrastructure
# (e.g. local Ollama for Pass 1, remote API for Pass 2). When both passes hit the same
# endpoint the overlap adds concurrency pressure without saving wall-clock time.
PIPELINE_STREAMING=0             # 1 = Pass1→Pass2 overlap; only enable for local→remote handoff
PIPELINE_BATCH_SIZE=2            # Chunks processed per LLM batch
# Optional per-pass batch size overrides. If set, these override
# the global PIPELINE_BATCH_SIZE for the respective pass.
PIPELINE_PASS1_BATCH_SIZE=4      # Pass 1: chunk batch size (default 4)
PIPELINE_PASS2_BATCH_SIZE=16     # Pass 2: statement batch size (default 16)
PIPELINE_MAX_WORKERS=5           # Parallel workers for LLM calls (applies to both passes unless overridden below)
# Optional per-pass worker overrides. Typical: local Pass 1 can use more workers (4-6) than
# a rate-limited remote Pass 2 (2-3). Falls back to PIPELINE_MAX_WORKERS when unset.
# Note: when using backends.yaml, per-backend worker counts are set there instead.
PASS1_MAX_WORKERS=               # Pass 1 worker count (blank = PIPELINE_MAX_WORKERS; suggested: 4-6 for local Ollama)
PASS2_MAX_WORKERS=               # Pass 2 worker count (blank = PIPELINE_MAX_WORKERS; suggested: 2-3 for OpenRouter)
PIPELINE_MAX_CHUNKS=             # Max chunks to process (blank = entire document)
PIPELINE_MIN_FACTS_PER_CONCEPT=1 # Prune concepts with at most this many facts
PIPELINE_ENRICH_THRESHOLD=6      # Enrich concepts with at most this many facts (set to 0 to disable)
PIPELINE_MIN_PUBLISHABLE_FACTS=2 # Drop stub concepts that still have fewer than this many facts after enrichment
PIPELINE_ENRICH_WORKERS=2        # Parallel workers for enrichment LLM calls (conservative: rate-limit safe)
PIPELINE_RENDER_WORKERS=4        # Parallel workers for page rendering (CPU-light string ops; 4 is a safe default)
PIPELINE_SYNTHESIS=0             # 1 = Pass 3 LLM synthesis: rewrites each page as rich prose (uses Pass 3 backend)
# Synthesis workers: safe to go higher when Pass 3 uses a local model (no rate limits).
# Keep at 1-2 when Pass 3 hits a remote API that shares quota with Pass 2.
PIPELINE_SYNTHESIS_WORKERS=2     # Suggested: 2-4 for local Ollama, 1-2 for remote API


# ── Output settings ───────────────────────────────────────────────────────────

ENHANCED_PAGE_MODE=1
# 1 = wiki-style pages with templates and wikilinks
# 0 = standard pages (definition + key points + related)
